# InsForge Configuration
# Copy this file to .env and fill in your values.
# Get these from your InsForge dashboard: https://insforge.dev

# Your InsForge backend base URL
VITE_INSFORGE_BASE_URL=https://your-app.region.insforge.app

# Used as the API base for all storage, database, and function calls
VITE_API_URL=https://your-app.region.insforge.app

# Anonymous JWT — used for client-side auth (sign-in/sign-up via InsForge hosted pages)
VITE_INSFORGE_ANON_KEY=your_insforge_anon_key_here
